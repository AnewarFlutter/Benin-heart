{
	"info": {
		"_postman_id": "admin-shoemaker-api",
		"name": "Shoemaker API - ADMIN (Administrateur)",
		"description": "Collection complète des endpoints ADMIN de l'API Shoemaker.\n\n## Authentification Requise\nTous les endpoints nécessitent :\n- Connexion avec context: \"ADMIN\" ou \"SUPERADMIN\"\n- Token JWT dans le header Authorization: Bearer {{access_token}}\n\n## Variables d'environnement\n- `base_url`: http://localhost:8000\n- `access_token`: Token JWT (auto-rempli après login)\n- `refresh_token`: Refresh token JWT",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "🔐 Authentification Admin",
			"item": [
				{
					"name": "Connexion Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set('access_token', jsonData.access);",
									"    pm.environment.set('refresh_token', jsonData.refresh);",
									"    console.log('✅ Tokens admin sauvegardés');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"admin@shoemaker.sn\",\n    \"password\": \"admin123\",\n    \"context\": \"ADMIN\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/login/",
							"host": ["{{base_url}}"],
							"path": ["api", "login", ""]
						},
						"description": "Connexion en tant qu'administrateur.\n\n**Contextes possibles :**\n- ADMIN : Administrateur\n- SUPERADMIN : Super administrateur"
					},
					"response": []
				},
				{
					"name": "Rafraîchir le Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    pm.environment.set('access_token', jsonData.access);",
									"    console.log('✅ Token rafraîchi');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/token/refresh/",
							"host": ["{{base_url}}"],
							"path": ["api", "token", "refresh", ""]
						},
						"description": "Rafraîchir le token d'accès lorsqu'il expire (après 24h)."
					},
					"response": []
				},
				{
					"name": "Déconnexion Admin",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/admin/logout/",
							"host": ["{{base_url}}"],
							"path": ["api", "admin", "logout", ""]
						},
						"description": "Déconnexion de l'administrateur. Ajoute le refresh token à la blacklist."
					},
					"response": []
				}
			],
			"description": "Endpoints d'authentification pour les administrateurs."
		},
